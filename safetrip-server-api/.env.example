# SafeTrip Backend (NestJS) - Environment Variables Template
# 사용법: cp .env.example .env → 실제 값으로 채울 것
NODE_ENV=development
PORT=3001

# ============================================================================
# PostgreSQL
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=safetrip_local
DB_USER=safetrip
DB_PASSWORD=your_db_password
DB_SSL=false

# ============================================================================
# JWT
# ============================================================================
JWT_SECRET=your_jwt_secret_minimum_32_chars

# ============================================================================
# Firebase
# ============================================================================
FIREBASE_PROJECT_ID=safetrip-urock
FIREBASE_CLIENT_EMAIL=your_service_account_email
FIREBASE_PRIVATE_KEY="your_private_key"
FIREBASE_DATABASE_URL=http://127.0.0.1:9000/?ns=safetrip-urock-default-rtdb

# ============================================================================
# Firebase Emulator (개발 환경)
# ============================================================================
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIREBASE_DATABASE_EMULATOR_HOST=localhost:9000
FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199
