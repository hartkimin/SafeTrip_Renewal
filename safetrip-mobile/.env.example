# SafeTrip Flutter - Environment Variables Template
# 환경별 사용법:
#   개발 (에뮬레이터): cp .env.example .env → IP를 실제 호스트 IP로 변경
#   개발 (ngrok):     bash ../scripts/start-dev-ngrok.sh (자동 설정)
#   Staging:          cp .env.staging .env
#   Production:       cp .env.production .env

API_SERVER_URL=http://10.0.2.2:3001

USE_FIREBASE_EMULATOR=true
FIREBASE_EMULATOR_HOST=10.0.2.2
FIREBASE_AUTH_EMULATOR_URL=http://10.0.2.2:9099
FIREBASE_RTDB_EMULATOR_URL=http://10.0.2.2:9000
FIREBASE_STORAGE_EMULATOR_URL=http://10.0.2.2:9199
